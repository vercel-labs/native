<column gap="6" padding="10">
  <text>{banner} filter {filter} next {nextId}</text>
  <text>done {doneCount} hover {hoveredId}</text>
  <if test="{selected}">
    <text>picked {selected}</text>
  </if>
  <row gap="4">
    <text-field text="{draft}" label="Draft" on-input="draft_edit" width="160" />
    <text>draft [{draft}]</text>
  </row>
  <media-surface surface="{previewSurface}" width="160" height="40" label="Preview" />
  <row gap="4">
    <stack>
      <button on-press="add">Add</button>
      <tooltip anchor="above" tooltip-delay="200">Add a task</tooltip>
    </stack>
    <button on-press="cycle">Cycle</button>
    <button on-press="clear">Clear</button>
  </row>
  <for each="tasks" as="t" key="id">
    <row key="{t.id}" gap="4" cross="center" on-hover-enter="hover_row:{t.id}" on-hover-leave="hover_off:{t.id}">
      <text grow="1">{t.title} #{t.id}</text>
      <if test="{t.done}">
        <badge>done</badge>
      </if>
      <button size="sm" on-press="toggle:{t.id}">Flip</button>
      <button size="sm" on-press="pick:{t.id}">Pick</button>
    </row>
  </for>
  <else>
    <text>no tasks</text>
  </else>
</column>
